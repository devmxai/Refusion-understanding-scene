        "endMs": 1200,
        "fromValue": { "x": 0, "y": 80 },
        "toValue": { "x": 0, "y": 0 },
        "easing": "easeOutCubic"
      },
      {
        "id": "title-opacity",
        "beatId": "title-enter",
        "targetComponentId": "title",
        "kind": "fade",
        "property": "opacity",
        "startMs": 400,
        "endMs": 900,
        "fromValue": 0.0,
        "toValue": 1.0,
        "easing": "easeOutCubic"
      },
      {
        "id": "title-typewriter",
        "beatId": "title-type",
        "targetComponentId": "title",
        "kind": "typewriter",
        "property": "typewriterProgress",
        "startMs": 1100,
        "endMs": 2300,
        "fromValue": 0.0,
        "toValue": 1.0,
        "easing": "linear"
      }
    ]
