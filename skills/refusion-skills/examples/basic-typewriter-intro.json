      },
      {
        "id": "title-type",
        "label": "Title types",
        "startMs": 1100,
        "endMs": 2300,
        "intent": "Reveal the title as keyboard typing.",
        "componentRefs": ["title"]
      },
      {
        "id": "readable-hold",
        "label": "Readable hold",
        "startMs": 2300,
        "endMs": 3200,
        "intent": "Hold the completed title long enough to read.",
        "componentRefs": ["title"]
      }
