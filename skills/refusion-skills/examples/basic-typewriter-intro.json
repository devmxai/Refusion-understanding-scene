{
  "directorPlan": {
    "schemaVersion": "refusion.motion-director/v1",
    "name": "Basic Typewriter Intro Plan",
    "durationMs": 3200,
    "frameRate": 30,
    "canvasWidth": 1080,
    "canvasHeight": 1920,
    "beats": [
      {
        "id": "background-enter",
        "label": "Background enters",
        "startMs": 0,
        "endMs": 500,
